# Copie para .env e preencha (NUNCA commite a chave real).
#   cp .env.example .env

# Chave da API da Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcionais
CLAUDE_MODEL=claude-opus-4-8
PORT=3000

# ── MCP Server remoto (mcp/http.js) ──
# URL pública do servidor (usada nos metadados de OAuth). Em produção,
# aponte para o host HTTPS onde o servidor está publicado.
MCP_PUBLIC_URL=http://localhost:3000
# Defina como "false" apenas em dev para testar as tools sem OAuth.
MCP_REQUIRE_AUTH=true
